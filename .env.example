# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Backend local runtime paths. Keep real local files under storage/local/.
STOCK_APP_DATA_HOME=storage/local
STOCK_APP_TEMPLATE_HOME=storage/templates
STOCK_APP_DB_PATH=storage/local/app.db

# Optional provider switches.
STOCK_APP_MARKET_PROVIDER=yfinance
